rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 팀 목록 - 앱 초기화 시 teams.js 기준으로 동기화
    match /teams/{teamName} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // 제출 현황 - 등록된 팀 이름으로만 쓰기 허용
    match /submissions/{teamName} {
      allow read: if true;
      allow write: if exists(/databases/$(database)/documents/teams/$(teamName));
    }

    // 심사 결과
    match /results/latest {
      allow read: if true;
      allow write: if true;
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
